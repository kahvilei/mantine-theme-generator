          "id": "refund",
          "question": "Can I get a refund?",
          "answer": "We offer a 14-day money-back guarantee on all plans. If you're not satisfied, contact support and we'll process a full refund."
        },
        {
          "id": "team",
          "question": "How do I add team members?",
          "answer": "Head to Settings → Team and click Invite. Team members can be assigned roles: Owner, Admin, or Viewer."
        },
        {
          "id": "data",
          "question": "Is my data secure?",
          "answer": "All data is encrypted at rest and in transit using AES-256. We are SOC 2 Type II certified and GDPR compliant."
        },
        {
          "id": "export",
          "question": "Can I export my data?",
          "answer": "Yes. You can export all your data as CSV or JSON at any time from the Settings → Export page."
        },
        {
          "id": "cancel",
          "question": "What happens when I cancel?",
          "answer": "Your account downgrades to the Free plan at the end of the current billing period. Your data is retained for 30 days."
        }
      ]
    }
